# Polymarket (Phase 3+ only)
# Run: .venv/bin/python scripts/setup_wallet.py to generate these
POLYMARKET_PRIVATE_KEY=
POLYMARKET_WALLET_ADDRESS=
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
POLYMARKET_PROXY_ADDRESS=
POLYMARKET_FUNDER_ADDRESS=

# PolyNode watched-wallet websocket
POLYNODE_API_KEY=
POLYNODE_WS_URL=wss://ws.polynode.dev/ws
POLYNODE_ENABLED=true
POLYNODE_SNAPSHOT_COUNT=50
POLYNODE_SUBSCRIPTION_TYPE=dome
WALLET_SYNC_FALLBACK_INTERVAL_SECONDS=300

# Infrastructure
DATABASE_URL=postgresql+asyncpg://whale:whale@localhost:5432/whale_bot
REDIS_URL=redis://localhost:6379/0

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Operational
LOG_LEVEL=INFO
LIVE_EXECUTION_ENABLED=false
STRICT_MODE=true
STARTING_CAPITAL=15000
